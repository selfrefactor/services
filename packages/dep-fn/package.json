{
	"name": "dep-fn",
	"scripts": {
		"lint:doesnt:work": "cd src&&run lx",
		"out": "tsc -p .",
		"in": "tsc -p . --watch",
		"debug": "yarn out&&node dist/debug.js",
		"test": "jest"
	},
	"main": "dist/index.js",
	"typings": "index.d.ts",
	"version": "2.2.0",
	"dependencies": {
		"fs-extra": "10.1.0",
		"helpers-fn": "1.6.0",
		"inquirer": "9.1.4",
		"json-format": "1.0.1",
		"package-storage": "1.0.0",
		"rambdax": "9.0.0"
	},
	"devDependencies": {
		"@types/fs-extra": "9.0.13",
		"@types/jest": "29.2.3",
		"@types/node": "18.11.9",
		"jest": "29.3.1",
		"ts-jest": "29.0.3",
		"tslint-fn": "0.5.0",
		"typescript": "4.9.3"
	},
	"jest": {
		"setupTestFrameworkScriptFile": "<rootDir>/node_modules/helpers-fn/jest/prepare.js",
		"transform": {
			"^.+\\.tsx?$": "ts-jest"
		},
		"testRegex": ".+spec.ts(x)?$",
		"moduleFileExtensions": [
			"ts",
			"js",
			"json"
		]
	},
	"repository": "https://github.com/selfrefactor/services/tree/master/packages/dep-fn",
	"license": "MIT",
	"author": "Dejan Toteff <deyan8284@gmail.com>",
	"description": "Easier update of Node.js dependencies",
	"private": false
}