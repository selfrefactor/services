{
	"name": "dep-fn",
	"scripts": {
		"out": "tsc -p .",
		"in": "tsc -p . --watch",
		"debug": "yarn out&&node dist/debug.js",
		"test": "jest"
	},
	"main": "dist/index.js",
	"typings": "index.d.ts",
	"version": "2.3.0",
	"depFn": [
		"inquirer"
	],
	"dependencies": {
		"fs-extra": "11.2.0",
		"helpers-fn": "1.8.2",
		"inquirer": "8.0.0",
		"json-format": "1.0.1",
		"package-storage": "1.0.0",
		"rambdax": "11.1.1"
	},
	"devDependencies": {
		"@types/fs-extra": "11.0.4",
		"@types/jest": "29.5.12",
		"@types/node": "20.14.11",
		"jest": "29.7.0",
		"ts-jest": "29.2.3",
		"tslint-fn": "0.5.0",
		"typescript": "5.5.3"
	},
	"jest": {
		"setupTestFrameworkScriptFile": "<rootDir>/node_modules/helpers-fn/jest/prepare.js",
		"transform": {
			"^.+\\.tsx?$": "ts-jest"
		},
		"testRegex": ".+spec.ts(x)?$",
		"moduleFileExtensions": [
			"ts",
			"js",
			"json"
		]
	},
	"repository": "https://github.com/selfrefactor/services/tree/master/packages/dep-fn",
	"license": "MIT",
	"author": "Dejan Toteff <deyan8284@gmail.com>",
	"description": "Easier update of Node.js dependencies",
	"private": false
}
