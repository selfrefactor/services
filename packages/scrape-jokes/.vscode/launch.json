{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Test File",
      "program": "${workspaceRoot}/node_modules/jest/bin/jest.js",
      "args": [
        "--verbose",
        "-i",
        "-u",
        "--no-cache",
        "${fileBasenameNoExtension}"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Nodejs File",
      "program": "${file}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Scrape",
      "program": "${workspaceRoot}/node_modules/jest/bin/jest.js",
      "args": [
        "src/run.spec.js",
        "https://vicovete.bg/category/%D0%BA%D0%B8%D1%84%D0%BB%D0%B8/page/5",
        "kifli"
      ],
      "env": {
        "HEADLESS": "OFF",
        "CHECK_FOR_UNIQUENESS": "OFF",
        "DEBUG": "ON"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
  ]
}
