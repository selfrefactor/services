{
	"scripts": {
		"small:1": "MODE=small node syncSettings",
		"read:small:1": "MODE=small READ=ON node syncSettings",
		"read:1": "READ=ON node syncSettings",
		"read:2": "BETA=ON READ=ON node syncSettings",
		"read:big:1": "MODE=big READ=ON node syncSettings",
		"on": "node visualize-keybindings && yarn on:1 && yarn on:2 && run d",
		"read": "yarn read:1 && yarn on:2",
		"readx": "x=1 yarn read",
		"on:1": "MODE=normal node syncSettings",
		"on:2": "BETA=ON MODE=normal node syncSettings",
		"big": "yarn big:1 &&yarn big:2",
		"big:1": "MODE=big node syncSettings",
		"big:2": "BETA=ON MODE=big node syncSettings"
	},
	"name": "vscode-control",
	"version": "0.1.0",
	"repository": "git@github.com:selfrefactor/services.git",
	"author": "Dejan Toteff <deyan8284@gmail.com>",
	"license": "MIT",
	"dependencies": {
		"esm": "3.2.25",
		"helpers-fn": "1.6.0",
		"fs-extra": "10.0.0",
		"rambdax": "8.0.1"
	},
	"commitLabels": [
		"keybinding",
		"extension",
		"snippet",
		"setting"
	],
	"devDependencies": {
		
	}
}
