[
  {
    "key": "alt+i",
    "comment": "==================SNIPPETS==================",
    "command": "editor.action.insertSnippet",
    "args": {
      "name": "If Snippet"
    }
  },
  {
    "key": "alt+1",
    "command": "editor.action.insertSnippet",
    "args": {
      "snippet": "console.log(${1:})"
    },
    "when": "editorLangId!=python"
  },
  {
    "key": "alt+1",
    "command": "editor.action.insertSnippet",
    "args": {
      "snippet": "print(${1:})"
    },
