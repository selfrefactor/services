{
	"FnAsyncSnippet": {
		"prefix": "async",
		"body": [
			"export async function $0(){",
			"\t",
			"}"
		],
		"description": "test async"
	},
	"Test Snippet": {
		"prefix": "test",
		"body": [
      "test('happy', () => {",
			"$0",
			"})"
		],
		"description": "test"
	},
	"Wallaby": {
		"prefix": "wal",
		"body": [
			"/*?*/"
		],
		"description": "wallaby log"
	},
	"Require": {
		"prefix": "req",
		"body": [
			"const { ${1:method} } = require('${0}')"
		],
		"description": "require"
	},
	"RequireX": {
		"prefix": "reqx",
		"body": [
			"const { ${1:method} } = require('./${1:method}')"
		],
		"description": "requireX"
	},
	"commentMultiline": {
		"prefix": "com",
		"body": [
			"/**",
			" * $0",
			" */"
		],
		"description": "comment multiline"
	},
	"commentx": {
		"prefix": "comx",
		"body": [
			"// $0",
			"// ============================================"
		],
		"description": "comment with underline"
	},
	"StringTemplate": {
		"prefix": "str",
		"body": [
			"`${${0}}`"
		],
		"description": "str"
	},
	"StringTemplatex": {
		"prefix": "stx",
		"body": [
			"`${${0}}${}`"
		],
		"description": "stx"
	},
	"Export": {
		"prefix": "exportx",
		"body": [
			"exports.${1:module} = ${1:module}"
		],
		"description": "export"
	},
	"ExpectSnapshot": {
		"prefix": "snap",
		"body": [
			"expect(",
			"\t$0",
			").toMatchSnapshot()"
		]
	},
	"ExpectInlineSnapshot": {
		"prefix": "inline",
		"body": [
			"expect(",
			"\t$0",
			").toMatchInlineSnapshot()"
		]
	},
	"LogDebug": {
		"prefix": "lgd",
		"body": [
			"console.log({type: typeof ${1:toLog}})",
			"console.log({array: Array.isArray(${1:toLog}) ? ${1:toLog}.length : 'not array'})",
			"console.log( {keys: ${1:toLog} ? Object.keys(${1:toLog}) : 'not object'})",
			"console.log(${1:toLog})",
			"\n$0"
		],
		"description": "log and describe"
	}
}
