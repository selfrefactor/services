{
  "workbench.tree.enableStickyScroll": true,
  "workbench.tree.stickyScrollMaxItemCount": 5,
  "window.zoomPerWindow": true,
  "window.customTitleBarVisibility": "windowed",
  "terminal.integrated.mouseWheelZoom": true,
  "editor.suggest.selectionMode": "whenTriggerCharacter",
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.acceptSuggestionOnEnter": "smart",
  "editor.bracketPairColorization.enabled": false,
  "editor.cursorBlinking": "smooth",
  "editor.cursorBlinking.prev": "phase",
  "editor.cursorSmoothCaretAnimation": true,
  "editor.cursorStyle": "line-thin",
  "editor.inlayHints.enabled": "off",
  "editor.inlayHints.padding": true,
  "editor.parameterHints.enabled": false,
  "editor.suggestOnTriggerCharacters": false,
  "explorer.autoReveal": true,
  "references.preferredLocation": "view",
  "workbench.editor.enablePreviewFromQuickOpen": true,
  "workbench.editor.focusRecentEditorAfterClose": false,
  "workbench.editor.revealIfOpen": false,
  "ts.implicitProjectConfig.strictNullChecks": true,
  "js.implicitProjectConfig.strictNullChecks": true,
  "prettier.arrowParens": "always",
  "prettier.bracketSpacing": true,
  "prettier.endOfLine": "lf",
  "prettier.htmlWhitespaceSensitivity": "css",
  "prettier.insertPragma": false,
  "prettier.singleAttributePerLine": true,
  "prettier.bracketSameLine": false,
  "prettier.jsxSingleQuote": true,
  "prettier.printWidth": 69,
  "prettier.proseWrap": "never",
  "prettier.quoteProps": "as-needed",
  "prettier.requirePragma": false,
  "prettier.semi": false,
  "prettier.singleQuote": true,
  "prettier.tabWidth": 2,
  "prettier.trailingComma": "all",
  "prettier.useTabs": false,
  "prettier.embeddedLanguageFormatting": "auto",
  "breadcrumbs.symbolSortOrder": "type",
  "codemetrics.basics.ComplexityLevelExtremeDescription": "",
  "codemetrics.basics.ComplexityLevelHighDescription": "",
  "codemetrics.basics.ComplexityLevelLowDescription": "",
  "codemetrics.basics.ComplexityLevelNormalDescription": "",
  "codemetrics.basics.ComplexityColorExtreme": "#d439",
  "codemetrics.basics.ComplexityColorHigh": "#8437",
  "codemetrics.basics.ComplexityColorLow": "#4b47",
  "codemetrics.basics.ComplexityColorNormal": "#fc07",
  "magicBeans.RANDOM_FILE_ALLOWED": [
    ".feature",
    ".js",
    ".md",
    "package.json",
    ".rs",
    ".vtl",
    ".ts",
    ".tsx"
  ],
  "magicBeans.RANDOM_FILE_FORBIDDEN": [
    "__tests__",
    ".gitconfig",
    ".gitignore",
    ".pylintrc",
    ".spec.js",
    ".spec.ts",
    "index.tsx",
    "index.ts",
    "index.js",
    "config.js",
    "config.ts",
    ".spec.tsx",
    ".test.js",
    ".test.ts",
    ".test.tsx",
    ".story.tsx",
    ".stories.tsx",
    "Makefile",
    "package-lock.json",
    "pre-commit"
  ],
  "magicBeans.RANDOM_FILE_SKIP_DIRECTORIES": [
    "__tests__",
    "test",
    "tests",
    "styles",
    "node_modules",
    "stories",
    "coverage",
    "vendor",
    "bin",
    "dist",
    "build",
    ".vscode",
    ".idea",
    ".git",
    ".cache"
  ],
  "workbench.editor.dragToOpenWindow": false,
  "files.autoSave": "off",
  "zenMode.hideActivityBar": false
}