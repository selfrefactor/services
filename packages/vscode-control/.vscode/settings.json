{
  "github.copilot.enable": {
    "*": true,
    "yaml": true,
    "plaintext": true,
    "markdown": true
  },
  "telemetry.telemetryLevel": "off",
  "typescript.tsserver.experimental.enableProjectDiagnostics": false,
  "window.commandCenter": true,
  "wallaby.suppressExpirationNotifications": true,
  "zenMode.centerLayout": true,
  "workbench.editor.revealIfOpen": false,
  "workbench.editor.enablePreview": false,
  "editor.hover.delay": 600,
  "workbench.iconTheme": "emoji-file-icons",
  "editor.guides.bracketPairs":false,
  "editor.bracketPairColorization.enabled": false,
  "explorer.autoReveal": true,
  "javascript.inlayHints.enumMemberValues.enabled": false,
  "javascript.inlayHints.functionLikeReturnTypes.enabled": false,
  "javascript.inlayHints.parameterTypes.enabled": false,
  "javascript.inlayHints.propertyDeclarationTypes.enabled": false,
  "javascript.inlayHints.variableTypes.enabled": false,
  "typescript.inlayHints.enumMemberValues.enabled": false,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": false,
  "typescript.inlayHints.parameterTypes.enabled": false,
  "typescript.inlayHints.variableTypes.enabled": false,
  "editor.scrollbar.vertical": "visible",
  "explorer.openEditors.sortOrder": "alphabetical",
  "explorer.sortOrder": "default",
  "editor.quickSuggestions": {
    "comments": "off",
    "strings": "off",
    "other": "off"
  },
  "editor.tabCompletion": "off",
  "workbench.editor.enablePreviewFromQuickOpen":true,
  "editor.hover.sticky": false,
  "files.enableTrash": false,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "scm.defaultViewMode": "tree",
  "git.fetchOnPull": true,
  "debug.javascript.usePreview": true,
  "workbench.list.smoothScrolling": true,
  "editor.semanticTokenColorCustomizations": {
    "enabled": true
  },
  "update.mode": "none",
  "javascript.preferences.importModuleSpecifierEnding": "auto",
  "js/ts.implicitProjectConfig.checkJs": true,
  "search.useReplacePreview": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "editor.acceptSuggestionOnCommitCharacter": false,
  "references.preferredLocation": "view",
  "json.format.enable": false,
  "task.autoDetect": "off",
  "task.quickOpen.detail": false,
  "zenMode.restore": false,
  "json.maxItemsComputed": 1000,
  "editor.semanticHighlighting.enabled": true,
  "editor.suggest.showIcons": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": false,
    "source.organizeImports": false
  },
  "search.collapseResults": "alwaysCollapse",
  "window.title": "${activeFolderMedium}/${activeEditorShort}",
  "zenMode.hideLineNumbers": true,
  "workbench.editor.labelFormat": "default",
  "workbench.editor.focusRecentEditorAfterClose": false,
  "files.exclude": {
    ".cache": true,
    "**/.awcache": true,
    "**/.cache-loader": true,
    "**/.DS_Store": false,
    "**/.git": true,
    "**/.idea": true,
    "**/.hg": false,
    "**/.svn": false,
    "**/coverage": true,
    "**/coverage-ts": true,
    "**/CVS": false,
    "**/node_modules": true,
    "**/yarn-error.log": true,
    "dev_dist": true,
    "dist": false,
    "docs": false,
    "yarn.lock": true
  },
  "breadcrumbs.enabled": false,
  "editor.acceptSuggestionOnEnter": "smart",
  "editor.formatOnPaste": false,
  "editor.mouseWheelZoom": true,
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "explorer.confirmDelete": false,
  "files.autoSave": "off",
  "git.autofetch": true,
  "npm.autoDetect": "off",
  "npm.packageManager": "yarn",
  "search.smartCase": true,
  "telemetry.enableTelemetry": false,
  "terminal.integrated.copyOnSelection": false,
  "workbench.startupEditor": "none",
  "wallaby.showUpdateNotifications": false,
  "wallaby.strictSSL": false,
  "wallaby.startAutomatically": false,
  "editor.minimap.enabled": false,
  "search.seedOnFocus": true,
  "magicBeans.RANDOM_FILE_ALLOWED_EXTENSIONS": [
    ".html",
    ".js",
    ".jsx",
    ".tsx",
    ".css",
    ".scss",
    ".py",
    ".ts",
    ".feature"
  ],
  "magicBeans.RANDOM_FILE_FORBIDDEN_EXTENSIONS": [],
  "editor.cursorSmoothCaretAnimation": true,
  "editor.cursorStyle": "line-thin",
  "editor.codeLens": true,
  "editor.smoothScrolling": true,
  "editor.lineNumbers": "interval",
  "editor.fontLigatures": true,
  "editor.parameterHints.enabled": false,
  "explorer.incrementalNaming": "smart",
  "editor.inlayHints.enabled": "off",
  "editor.suggest.shareSuggestSelections": false,
  "editor.suggestOnTriggerCharacters": true,
  "editor.quickSuggestionsDelay": 500,
  "comment.for.below": "new changes",
  "editor.cursorBlinking": "phase",
  "editor.inlayHints.padding": true,
  "terminal.integrated.gpuAcceleration": "off"
}
