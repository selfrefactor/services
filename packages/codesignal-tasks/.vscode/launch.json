{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Test File",
      "program": "${workspaceRoot}/node_modules/jest/bin/jest.js",
      "args": [
        "--verbose",
        "-i",
        "-u",
        "--no-cache",
        "${fileBasenameNoExtension}"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Nodejs File",
      "program": "${file}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Run challange",
      "program": "${workspaceRoot}/node_modules/jest/bin/jest.js",
      "args": [
        "--verbose",
        "-i",
        "-u",
        "--no-cache",
        "src/run-challenge.spec.js",
        "h9TndHHMewEvesw3o"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "HEADLESS": "OFF"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Scrape challenge",
      "program": "${workspaceRoot}/node_modules/jest/bin/jest.js",
      "args": [
        "--verbose",
        "-i",
        "--no-cache",
        "src/run-challenge.spec.js",
        "MCvv9beeFd96hWwRe"
      ],
      "env": {
        "HEADLESS": "ON",
        "DEBUG": "ON"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
  ]
}
