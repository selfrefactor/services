{
	"name": "magic-beans",
	"scripts": {
		"test": "jest src/_modules",
		"postinstall": "node ./node_modules/vscode/bin/install"
	},
	"main": "./src/extension",
	"version": "2.5.0",
	"dependencies": {
		"helpers-fn": "1.6.0",
		"rambdax": "8.0.1",
		"string-fn": "3.1.0"
	},
	"devDependencies": {
		"@babel/core": "7.17.5",
		"@babel/plugin-proposal-object-rest-spread": "7.17.3",
		"@babel/preset-env": "7.16.11",
		"@types/jest": "27.4.1",
		"jest": "27.5.1",
		"typescript": "4.6.2",
		"vscode": "1.1.37"
	},
	"jest": {
		"moduleFileExtensions": [
			"js"
		],
		"testRegex": ".+spec.js$"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/selfrefactor/services/tree/master/packages/magic-beans"
	},
	"icon": "files/magic-beans.png",
	"displayName": "Magic Beans",
	"description": "Magic-like helpers",
	"publisher": "selfrefactor",
	"engines": {
		"vscode": "^1.30.1"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onCommand:magicBeans.betterCut",
		"onCommand:magicBeans.copyTrimmed",
		"onCommand:magicBeans.formatJson",
		"onCommand:magicBeans.createSpec",
		"onCommand:magicBeans.sortLines",
		"onCommand:magicBeans.randomFile"
	],
	"contributes": {
		"commands": [
			{
				"command": "magicBeans.randomFile",
				"title": "Start Magic Beans random file mode"
			},
			{
				"command": "magicBeans.requestRandomFile",
				"title": "Magic Beans request random file"
			},
			{
				"command": "magicBeans.createSpec",
				"title": "Create spec"
			},
			{
				"command": "magicBeans.formatJson",
				"title": "Format JSON"
			},
			{
				"command": "magicBeans.sortLines",
				"title": "Sort lines"
			}
		],
		"keybindings": [
			{
				"command": "magicBeans.sortLines",
				"key": "ctrl+shift+-"
			},
			{
				"command": "magicBeans.randomFile",
				"key": "f7"
			},
			{
				"command": "magicBeans.requestRandomFile",
				"key": "f6"
			},
			{
				"command": "magicBeans.createSpec",
				"key": "ctrl+shift+0"
			},
			{
				"command": "magicBeans.copyTrimmed",
				"key": "alt+c",
				"when": "editorTextFocus"
			}
		],
		"configuration": {
			"type": "object",
			"title": "MagicBeans",
			"properties": {
				"magicBeans.RANDOM_FILE_FORBIDDEN_EXTENSIONS": {
					"type": "array",
					"uniqueItems": true,
					"items": {
						"type": "string"
					},
					"default": [
						".test.ts",
						".test.tsx",
						".spec.ts",
						".spec.tsx",
						".test.js",
						".test.jsx",
						".spec.js",
						".spec.jsx"
					],
					"description": "Which file extensions are forbidden in random file mode"
				},
				"magicBeans.RANDOM_FILE_ALLOWED_EXTENSIONS": {
					"type": "array",
					"uniqueItems": true,
					"items": {
						"type": "string"
					},
					"default": [
						".html",
						".js",
						".jsx",
						".tsx",
						".css",
						".scss",
						".ts"
					],
					"description": "Which file extensions are allowed in random file mode"
				},
				"magicBeans.RANDOM_FILE_SKIP_PATTERNS": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"uniqueItems": true,
					"default": [
						"node_modules",
						"coverage",
						"vendor",
						"bin",
						".git"
					],
					"description": "Which directories are excluded in random file mode"
				}
			}
		}
	}
}
